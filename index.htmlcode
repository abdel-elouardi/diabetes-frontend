<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prédiction Diabète</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 500px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 10px;
            font-size: 24px;
        }

        .subtitle {
            text-align: center;
            color: #888;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            color: #555;
            font-size: 14px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 10px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 14px;
            transition: border-color 0.3s;
            outline: none;
        }

        input:focus {
            border-color: #667eea;
        }

        button {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: opacity 0.3s;
        }

        button:hover { opacity: 0.9; }

        .result {
            margin-top: 20px;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            display: none;
        }

        .result.diabetique {
            background: #ffe0e0;
            border: 2px solid #ff6b6b;
            color: #d63031;
        }

        .result.non-diabetique {
            background: #e0ffe0;
            border: 2px solid #55efc4;
            color: #00b894;
        }

        .result h2 { font-size: 20px; margin-bottom: 5px; }
        .result p { font-size: 14px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🩺 Prédiction Diabète</h1>
        <p class="subtitle">Entrez les informations du patient</p>

        <div class="form-group">
            <label>Grossesses</label>
            <input type="number" id="Pregnancies" value="1" min="0">
        </div>
        <div class="form-group">
            <label>Glucose</label>
            <input type="number" id="Glucose" value="120" min="0">
        </div>
        <div class="form-group">
            <label>Pression artérielle</label>
            <input type="number" id="BloodPressure" value="70" min="0">
        </div>
        <div class="form-group">
            <label>Épaisseur de peau</label>
            <input type="number" id="SkinThickness" value="20" min="0">
        </div>
        <div class="form-group">
            <label>Insuline</label>
            <input type="number" id="Insulin" value="80" min="0">
        </div>
        <div class="form-group">
            <label>BMI</label>
            <input type="number" id="BMI" value="25" step="0.1" min="0">
        </div>
        <div class="form-group">
            <label>Fonction pedigree diabète</label>
            <input type="number" id="DiabetesPedigreeFunction" value="0.5" step="0.01" min="0">
        </div>
        <div class="form-group">
            <label>Âge</label>
            <input type="number" id="Age" value="30" min="1">
        </div>

        <button onclick="predict()">🔍 Prédire</button>

        <div class="result" id="result">
            <h2 id="result-label"></h2>
            <p id="result-prob"></p>
        </div>
    </div>

    <script>
        async function predict() {
            const data = {
                Pregnancies: parseFloat(document.getElementById('Pregnancies').value),
                Glucose: parseFloat(document.getElementById('Glucose').value),
                BloodPressure: parseFloat(document.getElementById('BloodPressure').value),
                SkinThickness: parseFloat(document.getElementById('SkinThickness').value),
                Insulin: parseFloat(document.getElementById('Insulin').value),
                BMI: parseFloat(document.getElementById('BMI').value),
                DiabetesPedigreeFunction: parseFloat(document.getElementById('DiabetesPedigreeFunction').value),
                Age: parseFloat(document.getElementById('Age').value)
            };

            const response = await fetch('https://diabetes-projet-v2-production.up.railway.app/predict', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            const resultDiv = document.getElementById('result');
            const resultLabel = document.getElementById('result-label');
            const resultProb = document.getElementById('result-prob');

            resultDiv.style.display = 'block';
            resultLabel.textContent = result.label;
            resultProb.textContent = `Probabilité : ${result.probabilité}%`;

            if (result.prediction === 1) {
                resultDiv.className = 'result diabetique';
            } else {
                resultDiv.className = 'result non-diabetique';
            }
        }
    </script>
</body>
</html>